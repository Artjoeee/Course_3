{
  "Logging": {
    "LogLevel": {
      "Default": "Trace",
      "Microsoft": "Error",
      "Microsoft.Hosting.Lifetime": "Critical",
      "Microsoft.AspNetCore": "Warning"
    },

    "Console": {
      "LogLevel": {
        "Default": "Warning"
      }
    },
    "Debug": {
      "LogLevel": {
        "Default": "Debug"
      }
    },
    "File": {
      "LogLevel": {
        "Default": "Trace"
      }
    }
  },

  "WaitEnqueue": 5,

  "AllowedHosts": "*"
}
